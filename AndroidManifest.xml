<manifest xmlns:android="http://schemas.android.com/apk/res/android"
        package="com.wanleung.android.Stroke5"
        android:versionCode="2"
        android:versionName="@string/ime_version">

    <uses-sdk android:minSdkVersion="21" android:targetSdkVersion="34" />
    <application android:label="@string/ime_name"
            android:icon="@drawable/ic_launcher"
            android:allowBackup="true"
            android:supportsRtl="true"
            android:theme="@style/AppTheme">
        <service android:name="com.wanleung.android.Stroke5.StrokeFiveKeyboard"
                android:exported="true"
                android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data android:name="android.view.im" android:resource="@xml/method" />
        </service>

        <activity android:name="com.wanleung.android.Stroke5.MainActivity"
                android:exported="true"
                android:label="@string/ime_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name="com.wanleung.android.Stroke5.Setting"
                android:exported="false"
                android:label="@string/ime_name">
        </activity>

    </application>
</manifest>
